{
  "expo": {
    "name": "CloudPocket",
    "slug": "cloudpocket",
    "scheme": "cloudpocket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2B4C7E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ethankim.cloudpocket",
      "appleTeamId": "Y3RX7DCMNV",
      "infoPlist": {
        "CFBundleDisplayName": "CloudPocket",
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2B4C7E"
      },
      "package": "com.ethankim.cloudpocket"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
